---
interface Props {
  href: string;
  label: string;
  class?: string;
}
const { href, label, class: className = "" } = Astro.props;
---

<a href={href} class={`xp-button ${className}`}>
  <span class="xp-button__chrome">
    <span class="xp-button__label">{label}</span>
  </span>
</a>

<style>
  /*
   * XP Standard button — Luna theme, Figma spec mapped 1:1.
   *
   * Two-layer geometry from the source spec:
   *   outer frame  (75×23, padding: 1px, min-width: 75px, grows inline)
   *   inner chrome (73×21, padding: 3px 12px, the actual styled pill)
   *
   * Visual treatment is the spec's "default" state. Hover / focus /
   * active / disabled extend it minimally — XP's Luna theme amber
   * hot-track on hover, dotted inner outline on keyboard focus,
   * pressed-in look on active, flat low-contrast on disabled.
   */

  /* ── Outer frame ───────────────────────────────────────────── */
  .xp-button {
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
    box-sizing: border-box;

    padding: 1px;
    min-width: 75px;
    height: 23px;

    text-decoration: none;
    user-select: none;
    cursor: default;
  }

  /* ── Inner chrome ──────────────────────────────────────────── */
  .xp-button__chrome {
    box-sizing: border-box;
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    flex: 1;
    align-self: stretch;

    padding: 3px 12px;

    background: linear-gradient(180deg, #ffffff 0%, #f0f0ea 100%);
    border: 1px solid #1c5180;
    border-radius: 2.5px;
    box-shadow:
      1px 1px 0px rgba(255, 255, 255, 0.75),
      -1px -1px 0px rgba(0, 0, 0, 0.05),
      inset 1.5px 1.5px 2px #ffffff,
      inset -1.5px -2.5px 2px rgba(83, 55, 0, 0.2);
  }

  /* ── Label ─────────────────────────────────────────────────── */
  .xp-button__label {
    display: flex;
    align-items: center;
    text-align: center;

    font-family: "Tahoma", Geneva, Verdana, sans-serif;
    font-style: normal;
    font-weight: 400;
    font-size: 11px;
    line-height: 13px;
    color: #000000;
    white-space: nowrap;
  }

  /* ── State: hover (Luna amber hot-track) ───────────────────── */
  .xp-button:hover .xp-button__chrome {
    background: linear-gradient(180deg, #ffffff 0%, #fdf5d1 50%, #f8d978 100%);
    border-color: #e1a91a;
    box-shadow:
      1px 1px 0px rgba(255, 255, 255, 0.75),
      -1px -1px 0px rgba(0, 0, 0, 0.05),
      inset 1.5px 1.5px 2px #ffffff,
      inset -1.5px -2.5px 2px rgba(180, 110, 0, 0.25);
  }

  /* ── State: focus (dotted inner outline) ───────────────────── */
  .xp-button:focus-visible {
    outline: none;
  }
  .xp-button:focus-visible .xp-button__chrome {
    outline: 1px dotted #000;
    outline-offset: -3px;
  }

  /* ── State: active (gradient inverted, pressed in) ─────────── */
  .xp-button:active .xp-button__chrome {
    background: linear-gradient(180deg, #d8d8d2 0%, #ffffff 100%);
    box-shadow:
      inset 1px 1px 1px rgba(0, 0, 0, 0.18),
      inset 1.5px 1.5px 2px rgba(0, 0, 0, 0.1);
  }

  /* ── State: disabled ───────────────────────────────────────── */
  .xp-button[aria-disabled="true"] {
    cursor: not-allowed;
    pointer-events: none;
  }
  .xp-button[aria-disabled="true"] .xp-button__chrome {
    background: linear-gradient(180deg, #f4f4f4 0%, #ececec 100%);
    border-color: #b8b8b8;
    box-shadow: none;
  }
  .xp-button[aria-disabled="true"] .xp-button__label {
    color: #888;
  }
</style>
